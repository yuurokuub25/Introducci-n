//CREAR UN PROGRAMA QUE CALCULE EL DESCUENTO DE UN 25% DE UN SALARIO DEVENGADO POR UN EMPLEADO 

PROCESO DESCUENTO
 ESCRIBIR "PROGRAMA QUE DESCUENTA EL 25%"
 ESCRIBIR "DIGITE SU NOMBRE"
 LEER NOMBRE 
 ESCRIBIR "DIGITE SU SALARIO"
 LEER SALARIO
 PORCENTAJE= SALARIO * 25 / 100 // ESTA LINEA CALCULA EL PORCENTAJE
 RESULTADO= SALARIO - PORCENTAJE
 //CREAR UN PROGRAMA QUE CALCULE EL DESCUENTO DE UN 25% DE UN SALARIO DEVENGADO POR UN EMPLEADO 

   SI RESULTADO > 1000000 ENTONCES 
     ESCRIBIR "SU SALARIO ES MUY ALTO, USTED GANA ",RESULTADO
   SINO 
     ESCRIBIR "SU SALARIO ES MENOR A UN MILLON, USTED GANA ",RESULTADO
 FINSI
