//PROGRAMA PARA CALCULAR EL AREA Y PERIMETRO DE UNA CIRCUNFERENCIA A PARTIR DE SU DIAMETRO
PROCESOCALCULADORA
 ESCRIBIR "CALCULADORA DE AREA Y PERIMETRO DE UNA CIRCUNFERENCIA "
 ESCRIBIR "."
 ESCRIBIR "."
 ESCRIBIR "DIGITE EL DIAMETRO DE LA CIRCUNFERENCIA"
 LEER DIAMETRO
 RADIO = DIAMETRO/2
 AREA = 3.1416 * RADIO * RADIO
 PERIMETRO= (2 * 3.1416) * RADIO
 ESCRIBIR "EL RESULTADO DEL AREA ES ",AREA
 ESCRIBIR "EL RESULTADO DEL PERIMETRO ES ", PERIMETRO
 FINPROCESO
 
